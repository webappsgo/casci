### Resource Limits

```go
type ResourceManager struct {
    cpu    *CPUManager
    memory *MemoryManager
    disk   *DiskManager
}

func (rm *ResourceManager) AllocateForBuild(build *Build) (*Resources, error) {
    resources := &Resources{}
    
    // CPU allocation
    cpuRequest := build.Requirements.CPU
    if cpuRequest == 0 {
        cpuRequest = 1 // Default 1 CPU
    }
    
    if !rm.cpu.Available(cpuRequest) {
        return nil, ErrInsufficientCPU
    }
    resources.CPU = rm.cpu.Allocate(cpuRequest)
    
    // Memory allocation
    memRequest := build.Requirements.Memory
    if memRequest == 0 {
        memRequest = 2 * GB // Default 2GB
    }
    
    if !rm.memory.Available(memRequest) {
        rm.cpu.Release(resources.CPU)
        return nil, ErrInsufficientMemory
    }
    resources.Memory = rm.memory.Allocate(memRequest)
    
    // Disk allocation
    diskRequest := build.Requirements.Disk
    if diskRequest == 0 {
        diskRequest = 10 * GB // Default 10GB
    }
    
    if !rm.disk.Available(diskRequest) {
        rm.cpu.Release(resources.CPU)
        rm.memory.Release(resources.Memory)
        return nil, ErrInsufficientDisk
    }
    resources.Disk = rm.disk.Allocate(diskRequest)
    
    return resources, nil
}
```

