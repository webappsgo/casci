### systemd Service

```ini
[Unit]
Description=CASCI - CI/CD Application Server
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/var/lib/casci
ExecStart=/usr/local/bin/casci
Restart=always
RestartSec=10
StandardOutput=append:/var/log/casci/casci.log
StandardError=append:/var/log/casci/casci.log

# Security
NoNewPrivileges=false
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/casci /var/log/casci /etc/casci

[Install]
WantedBy=multi-user.target
```

### Docker Installation

```dockerfile
FROM alpine:3.19
RUN apk add --no-cache git docker-cli
COPY casci /usr/local/bin/
VOLUME ["/var/lib/casci", "/var/log/casci", "/etc/casci"]
EXPOSE 8080
CMD ["casci"]
```

```bash
# Run CASCI in Docker
docker run -d \
  --name casci \
  -p 8080:8080 \
  -v /var/run/docker.sock:/var/run/docker.sock \
  -v casci-data:/var/lib/casci \
  -v casci-logs:/var/log/casci \
  casci/casci:latest
```

