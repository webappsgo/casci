### Artifact Operations

```go
type ArtifactManager struct {
    storage Storage
    dedup   *Deduplicator
}

func (am *ArtifactManager) Store(artifact *Artifact) error {
    // Calculate hash for deduplication
    hash := calculateHash(artifact.Content)
    
    // Check if already exists
    if am.dedup.Exists(hash) {
        // Just create reference
        return am.dedup.CreateLink(hash, artifact.Path)
    }
    
    // Compress
    compressed := compress(artifact.Content)
    
    // Store
    path := generatePath(artifact)
    if err := am.storage.Put(path, compressed); err != nil {
        return err
    }
    
    // Update dedup index
    am.dedup.Add(hash, path)
    
    // Set retention
    am.scheduleCleanup(path, artifact.Retention)
    
    return nil
}

func (am *ArtifactManager) Retrieve(build *Build, name string) (*Artifact, error) {
    path := fmt.Sprintf("%s/%s/%d/%s", 
        build.User, build.Project, build.Number, name)
    
    // Get from storage
    content, err := am.storage.Get(path)
    if err != nil {
        return nil, err
    }
    
    // Decompress
    decompressed := decompress(content)
    
    return &Artifact{
        Name:    name,
        Content: decompressed,
        Build:   build,
    }, nil
}
```

