## Migration Tools

### Jenkins Migration

```yaml
Migration Process:

1. Export from Jenkins:
   - GET /job/*/config.xml
   - Parse job configurations
   - Extract credentials
   - Export build history

2. Convert to CASCI:
   - Map plugins to native
   - Convert pipeline scripts
   - Translate parameters
   - Preserve relationships

3. Import to CASCI:
   - Create projects
   - Import credentials
   - Set up webhooks
   - Verify builds

Supported Elements:
  - Freestyle jobs
  - Pipeline jobs
  - Multibranch pipelines
  - Folders/organization
  - Credentials
  - Build parameters
  - Build triggers
  - Post-build actions
```

### Migration API

```go
type JenkinsMigrator struct {
    jenkins *JenkinsClient
    casci   *CASCIClient
}

func (jm *JenkinsMigrator) MigrateAll() error {
    // Get all Jenkins jobs
    jobs, err := jm.jenkins.GetAllJobs()
    if err != nil {
        return err
    }
    
    for _, job := range jobs {
        // Get job config
        config, err := jm.jenkins.GetJobConfig(job.Name)
        if err != nil {
            log.Printf("Failed to get config for %s: %v", job.Name, err)
            continue
        }
        
        // Convert to CASCI format
        project := jm.convertJob(config)
        
        // Create in CASCI
        if err := jm.casci.CreateProject(project); err != nil {
            log.Printf("Failed to create project %s: %v", project.Name, err)
            continue
        }
        
        // Migrate credentials
        if err := jm.migrateCredentials(job); err != nil {
            log.Printf("Failed to migrate credentials: %v", err)
        }
        
        // Set up webhooks
        if err := jm.setupWebhooks(project); err != nil {
            log.Printf("Failed to setup webhooks: %v", err)
        }
        
        log.Printf("Migrated %s successfully", job.Name)
    }
    
    return nil
}

func (jm *JenkinsMigrator) convertJob(config *JenkinsConfig) *Project {
    project := &Project{
        Name:        config.Name,
        Description: config.Description,
    }
    
    // Convert SCM
    if config.SCM != nil {
        project.Repository = config.SCM.URL
        project.Branch = config.SCM.Branch
    }
    
    // Convert builders to pipeline
    pipeline := &Pipeline{}
    for _, builder := range config.Builders {
        stage := jm.convertBuilder(builder)
        pipeline.Stages = append(pipeline.Stages, stage)
    }
    project.Pipeline = pipeline
    
    return project
}
```

