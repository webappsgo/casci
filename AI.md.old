DigitalOcean:
  - $0.036/hour
  - Full API support
  - Premium option
  - Global locations

Linode:
  - $0.018/hour
  - Full API support
  - Good balance
  - Reliable

Usage Model:
  - Provision on demand
  - Destroy after build
  - Never idle
  - Cost tracking
  - Budget limits
```

### Provider Management

```go
type CloudProvider interface {
    Provision(spec InstanceSpec) (*Instance, error)
    Destroy(id string) error
    List() ([]*Instance, error)
    GetCost(id string) (float64, error)
}

type CloudManager struct {
    providers map[string]CloudProvider
    budgets   map[string]BudgetLimit
}

func (cm *CloudManager) ProvisionForBuild(build *Build, user *User) (*Instance, error) {
    // Check user's providers
    provider := cm.selectProvider(user, build.Requirements)
    
    // Check budget
    if !cm.checkBudget(user, provider) {
        return nil, ErrBudgetExceeded
    }
    
    // Provision instance
    instance, err := provider.Provision(InstanceSpec{
        Type: build.Requirements.InstanceType,
        Image: "ubuntu-22.04",
        UserData: generateCloudInit(build),
    })
    
    if err != nil {
        return nil, err
    }
    
    // Schedule destruction
    go cm.scheduleDestruction(instance, build.EstimatedDuration)
    
    return instance, nil
}

func (cm *CloudManager) scheduleDestruction(instance *Instance, duration time.Duration) {
    // Wait for build completion or timeout
    timer := time.NewTimer(duration + 5*time.Minute)
    defer timer.Stop()
    
    select {
    case <-timer.C:
    case <-instance.BuildComplete:
    }
    
    // Destroy immediately
    cm.providers[instance.Provider].Destroy(instance.ID)
    
    // Update billing
    cm.updateBilling(instance)
}
```

