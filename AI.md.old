## Installation & Setup

### System Preparation

```bash
#!/bin/bash
# CASCI Installation Script

set -e

# Detect OS and Architecture
OS=$(uname -s | tr '[:upper:]' '[:lower:]')
ARCH=$(uname -m)

case $ARCH in
    x86_64) ARCH="amd64" ;;
    aarch64) ARCH="arm64" ;;
    arm64) ARCH="arm64" ;;
    *) echo "Unsupported architecture: $ARCH"; exit 1 ;;
esac

# Download appropriate binary
DOWNLOAD_URL="https://github.com/casci/casci/releases/latest/download/casci-${OS}-${ARCH}"
echo "Downloading CASCI for ${OS}/${ARCH}..."
curl -L -o casci "${DOWNLOAD_URL}"

# Make executable and move to system location
chmod +x casci
sudo mv casci /usr/local/bin/

# Create necessary directories
sudo mkdir -p /var/lib/casci
sudo mkdir -p /var/log/casci
sudo mkdir -p /etc/casci

# Install dependencies if missing
if ! command -v docker &> /dev/null; then
    echo "Installing Docker..."
    curl -fsSL https://get.docker.com | sh
    sudo usermod -aG docker $USER
fi

if ! command -v git &> /dev/null; then
    echo "Installing Git..."
    sudo apt-get update && sudo apt-get install -y git || \
    sudo yum install -y git || \
    sudo dnf install -y git
fi

# Start CASCI
echo "Starting CASCI..."
sudo casci

echo "CASCI is running! Access at http://localhost:<port>"
echo "First user to register becomes administrator"
```

