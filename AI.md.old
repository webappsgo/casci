### Notification Configuration

```go
type NotificationConfig struct {
    Type     string // slack, email, webhook
    URL      string
    Template string
    Events   []string // success, failure, started
    Filter   string   // Condition
}

func sendNotification(build *Build, event string, config NotificationConfig) {
    // Check if should send
    if !contains(config.Events, event) {
        return
    }
    
    if !evaluateFilter(config.Filter, build) {
        return
    }
    
    // Prepare message
    message := renderTemplate(config.Template, NotificationData{
        Project:   build.Project,
        Branch:    build.Branch,
        Commit:    build.Commit,
        Author:    build.Author,
        Status:    build.Status,
        Duration:  build.Duration,
        URL:       build.URL,
        Artifacts: build.Artifacts,
    })
    
    // Send based on type
    switch config.Type {
    case "slack":
        sendSlack(config.URL, message)
    case "email":
        sendEmail(config.Recipients, message)
    case "webhook":
        sendWebhook(config.URL, message)
    }
}
```

