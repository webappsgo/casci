### API Authentication

```go
type APIAuth struct {
    tokens map[string]*Token
    mu     sync.RWMutex
}

func (a *APIAuth) Authenticate(r *http.Request) (*User, error) {
    // Check bearer token
    if auth := r.Header.Get("Authorization"); auth != "" {
        token := strings.TrimPrefix(auth, "Bearer ")
        return a.validateToken(token)
    }
    
    // Check API key
    if key := r.Header.Get("X-API-Key"); key != "" {
        return a.validateAPIKey(key)
    }
    
    // Check session cookie
    if cookie, err := r.Cookie("session"); err == nil {
        return a.validateSession(cookie.Value)
    }
    
    // Jenkins compatibility
    if user := r.URL.Query().Get("user"); user != "" {
        token := r.URL.Query().Get("token")
        return a.validateJenkinsToken(user, token)
    }
    
    return nil, ErrUnauthorized
}

func (a *APIAuth) RateLimit(user *User, r *http.Request) error {
    key := fmt.Sprintf("%s:%s", user.ID, r.URL.Path)
    
    if a.exceedsLimit(key) {
        return ErrRateLimitExceeded
    }
    
    a.increment(key)
    return nil
}
```

