### Format Detection

```go
func detectCIFormat(repo *Repository) CIFormat {
    // Priority order (if multiple exist)
    checks := []struct{
        path string
        format CIFormat
    }{
        {"Jenkinsfile", JenkinsFormat},
        {".github/workflows", GitHubActionsFormat},
        {".gitlab-ci.yml", GitLabCIFormat},
        {".circleci/config.yml", CircleCIFormat},
        {".travis.yml", TravisCIFormat},
        {"azure-pipelines.yml", AzureFormat},
        {"bitbucket-pipelines.yml", BitbucketFormat},
        {".drone.yml", DroneFormat},
        {"buildkite.yml", BuildkiteFormat},
    }
    
    for _, check := range checks {
        if repo.FileExists(check.path) {
            return check.format
        }
    }
    
    return NoFormat // Will auto-generate
}
```

