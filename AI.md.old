### Monitoring Integration

```go
type MetricsCollector struct {
    prometheus *prometheus.Registry
    
    // Counters
    buildsTotal     prometheus.Counter
    buildsSuccess   prometheus.Counter
    buildsFailed    prometheus.Counter
    
    // Gauges
    buildsQueued    prometheus.Gauge
    buildsRunning   prometheus.Gauge
    nodesOnline     prometheus.Gauge
    
    // Histograms
    buildDuration   prometheus.Histogram
    queueTime       prometheus.Histogram
    apiLatency      prometheus.Histogram
}

func (mc *MetricsCollector) RecordBuild(build *Build) {
    mc.buildsTotal.Inc()
    
    if build.Status == "success" {
        mc.buildsSuccess.Inc()
    } else {
        mc.buildsFailed.Inc()
    }
    
    mc.buildDuration.Observe(build.Duration.Seconds())
    mc.queueTime.Observe(build.QueueTime.Seconds())
}

// Prometheus endpoint
func (mc *MetricsCollector) Handler() http.Handler {
    return promhttp.HandlerFor(
        mc.prometheus,
        promhttp.HandlerOpts{},
    )
}
```

