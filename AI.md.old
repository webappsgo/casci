### Security Scanning Pipeline

```go
func securityScan(build *Build) SecurityReport {
    report := SecurityReport{
        BuildID: build.ID,
        Scans: []ScanResult{},
    }
    
    // Container scanning
    if build.HasContainer {
        trivyResult := runTrivy(build.Container)
        report.Scans = append(report.Scans, trivyResult)
    }
    
    // Source code scanning
    semgrepResult := runSemgrep(build.SourcePath)
    report.Scans = append(report.Scans, semgrepResult)
    
    // Secret scanning
    gitleaksResult := runGitleaks(build.SourcePath)
    report.Scans = append(report.Scans, gitleaksResult)
    
    // License compliance
    licenseResult := runLicenseCheck(build.SourcePath)
    report.Scans = append(report.Scans, licenseResult)
    
    // SBOM generation
    sbom := generateSBOM(build)
    report.SBOM = sbom
    
    // Binary signing (if applicable)
    if build.ProducesBinary {
        signBinaries(build)
    }
    
    return report
}
```

