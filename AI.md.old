### Auto-Detection

```go
func analyzeProject(repoURL string, user *User) *ProjectConfig {
    // Clone with user's token
    repo := cloneTemp(repoURL, user.GitToken)
    defer cleanup(repo)
    
    config := &ProjectConfig{
        Name: extractProjectName(repoURL),
        URL:  repoURL,
    }
    
    // Language detection
    config.Language = detectLanguage(repo)
    config.Version = detectLanguageVersion(repo)
    
    // Framework detection
    config.Framework = detectFramework(repo)
    config.FrameworkVersion = detectFrameworkVersion(repo)
    
    // Build tool detection
    config.BuildTool = detectBuildTool(repo)
    config.PackageManager = detectPackageManager(repo)
    
    // Test framework detection
    config.TestFramework = detectTestFramework(repo)
    config.TestCommand = generateTestCommand(config)
    
    // CI/CD detection
    if existing := detectExistingCI(repo); existing != nil {
        config.ImportedFrom = existing.Type
        config.Pipeline = convertToCASCI(existing)
    } else {
        // Generate optimal pipeline
        config.Pipeline = generateOptimalPipeline(config)
    }
    
    // Deployment detection
    config.DeploymentTarget = detectDeploymentTarget(repo)
    config.ContainerRegistry = detectRegistry(repo)
    
    return config
}
```

